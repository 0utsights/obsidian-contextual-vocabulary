{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": [
      "DOM",
      "ES2020",
      "ES2022.Intl"
    ],
    "moduleResolution": "Bundler",
    "importHelpers": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
